<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="KaiCoinMiner.App.MainWindow"
        Title="KaiCoin Miner">
    <Grid ClipToBounds="True">
        <Viewbox Stretch="UniformToFill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Canvas Width="1920" Height="1080" ClipToBounds="True">
                <Image Source="avares://KaiCoinMiner.App/Assets/Background.png"
                       Width="1920"
                       Height="1080"
                       Stretch="Fill" />

                <Border Canvas.Left="36"
                        Canvas.Top="28"
                        Width="1848"
                        Padding="16,10"
                        CornerRadius="10"
                        Background="#B912161A"
                        BorderBrush="#40E2E7F0"
                        BorderThickness="1">
                    <Grid ColumnDefinitions="Auto,20,Auto,20,Auto,*" VerticalAlignment="Center">
                        <TextBlock Name="CoinsText" Classes="mono" FontSize="20" Foreground="#F3F8FF" />
                        <TextBlock Grid.Column="1" Text="|" Opacity="0.55" Foreground="#EAF2FF" />
                        <TextBlock Name="CashText" Grid.Column="2" Classes="mono" FontSize="20" Foreground="#F3F8FF" />
                        <TextBlock Grid.Column="3" Text="|" Opacity="0.55" Foreground="#EAF2FF" />
                        <TextBlock Name="PriceText" Grid.Column="4" Classes="mono" FontSize="20" Foreground="#F3F8FF" />
                        <TextBlock Name="NewsTickerText" Grid.Column="5" Classes="mono" Margin="14,0,0,0" FontSize="18" Foreground="#D5E6FF" />
                    </Grid>
                </Border>

                <Border Canvas.Left="60"
                        Canvas.Top="250"
                        Width="720"
                        Height="430"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        ClipToBounds="True"
                        Padding="24,20">
                    <Grid RowDefinitions="*,Auto" RowSpacing="20" ClipToBounds="True">
                        <TextBlock Name="ChallengePromptText"
                                   Classes="mono"
                                   FontSize="64"
                                   FontWeight="Bold"
                                   Foreground="#F1FAFF"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   MaxLines="2"
                                   TextTrimming="WordEllipsis" />

                        <TextBlock Name="MonitorInputText"
                                   Grid.Row="1"
                                   Classes="mono"
                                   FontSize="36"
                                   FontWeight="SemiBold"
                                   Foreground="#AEE9FF"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxLines="1"
                                   TextTrimming="WordEllipsis" />
                    </Grid>
                </Border>

                <Button Name="SmartphoneButton"
                        Canvas.Left="1346"
                        Canvas.Top="598"
                        Width="184"
                        Height="44"
                        Content="Open Exchange" />

                <Border Canvas.Left="80"
                        Canvas.Top="724"
                        Width="590"
                        Padding="14"
                        CornerRadius="10"
                        Background="#C9151A22"
                        BorderBrush="#4DD7ECFF"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Utility Controls" FontSize="14" FontWeight="SemiBold" Foreground="#CFE8FF" Opacity="0.9" />
                        <WrapPanel Orientation="Horizontal">
                            <Button Name="MonkeyButton" Width="182" Height="34" HorizontalAlignment="Left" />
                            <Button Name="YouthButton" Width="182" Height="34" HorizontalAlignment="Left" />
                            <Button Name="GpuButton" Width="182" Height="34" HorizontalAlignment="Left" />
                            <Button Name="ManualUpgradeButton" Width="182" Height="34" HorizontalAlignment="Left" />
                            <Button Name="EfficiencyUpgradeButton" Width="182" Height="34" HorizontalAlignment="Left" />
                            <Button Name="MarketUpgradeButton" Width="182" Height="34" HorizontalAlignment="Left" />
                            <Button Name="SpaceshipButton" Width="182" Height="34" HorizontalAlignment="Left" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Canvas>
        </Viewbox>

        <Border Name="ExchangeOverlay"
                IsVisible="False"
                Background="#B0091016">
            <Border Width="760"
                    Height="500"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#F31A212B"
                    BorderBrush="#58D6F0FF"
                    BorderThickness="2"
                    CornerRadius="14"
                    Padding="18">
                <Grid RowDefinitions="Auto,220,Auto,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock FontSize="26" FontWeight="Bold" Foreground="#F3FAFF" Text="KaiCoin Exchange" />
                        <Button Name="CloseExchangeButton" Grid.Column="1" Width="100" Height="34" Content="Close" />
                    </Grid>

                    <Border Grid.Row="1" Background="#C50B1016" BorderBrush="#447EAAC8" BorderThickness="1" CornerRadius="8" Padding="10">
                        <Grid>
                            <Grid RowDefinitions="Auto,*,Auto" Margin="6,4,6,4">
                                <TextBlock Name="ExchangeMaxPriceText" Grid.Row="0" HorizontalAlignment="Right" FontSize="12" Opacity="0.78" Foreground="#D7EBFF" />

                                <Grid Grid.Row="1">
                                    <Border Name="ExchangeGuideTop" Height="1" Background="#3AF5EEE4" VerticalAlignment="Top" IsVisible="False" />
                                    <Border Name="ExchangeGuideMid" Height="1" Background="#2AF5EEE4" VerticalAlignment="Center" IsVisible="False" />
                                    <Border Name="ExchangeGuideBottom" Height="1" Background="#3AF5EEE4" VerticalAlignment="Bottom" IsVisible="False" />
                                </Grid>

                                <TextBlock Name="ExchangeMinPriceText" Grid.Row="2" HorizontalAlignment="Right" FontSize="12" Opacity="0.78" Foreground="#D7EBFF" />
                            </Grid>

                            <Polyline Name="ExchangePricePolyline"
                                      Stroke="#4FD0C9"
                                      StrokeThickness="2"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch" />

                            <TextBlock Name="ExchangeChartPlaceholder"
                                       Text="Collect at least 2 price points to render the chart"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Opacity="0.78"
                                       Foreground="#E1F0FF"
                                       IsVisible="True" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" ColumnDefinitions="2*,Auto,Auto" ColumnSpacing="8">
                        <TextBox Name="SellQuantityBox" Classes="mono" FontSize="18" PlaceholderText="Sell quantity" />
                        <Button Name="SellButton" Grid.Column="1" Width="110" Content="Sell" />
                        <TextBlock Name="ExchangeHintText" Grid.Column="2" VerticalAlignment="Center" Foreground="#EAA43C" />
                    </Grid>

                    <TextBlock Grid.Row="3" Text="Numeric keys route here while this modal is open. Enter sells." Opacity="0.8" Foreground="#CCE2F6" />
                </Grid>
            </Border>
        </Border>

        <Border Name="LaunchOverlay"
                IsVisible="False"
                Background="#BF030506">
            <Grid>
                <TextBlock Name="LaunchMessageText"
                           FontSize="36"
                           FontWeight="Bold"
                           Foreground="#F6FAFF"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,0,0,140" />
                <Border Name="RocketVisual"
                        Width="70"
                        Height="130"
                        CornerRadius="20"
                        Background="#EBE9D7"
                        BorderBrush="#364655"
                        BorderThickness="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,20" />
            </Grid>
        </Border>
    </Grid>
</Window>
