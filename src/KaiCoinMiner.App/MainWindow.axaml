<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="KaiCoinMiner.App.MainWindow"
        Title="KaiCoin Miner">
    <Grid RowDefinitions="Auto,*" Margin="18" RowSpacing="12">
        <Border Classes="panel" Grid.Row="0" Padding="12,10">
            <Grid ColumnDefinitions="Auto,24,Auto,24,Auto,*" VerticalAlignment="Center">
                <TextBlock Name="CoinsText" Classes="mono" FontSize="15" />
                <TextBlock Grid.Column="1" Text="|" Opacity="0.55" />
                <TextBlock Name="CashText" Grid.Column="2" Classes="mono" FontSize="15" />
                <TextBlock Grid.Column="3" Text="|" Opacity="0.55" />
                <TextBlock Name="PriceText" Grid.Column="4" Classes="mono" FontSize="15" />
                <TextBlock Name="NewsTickerText" Grid.Column="5" Classes="mono" HorizontalAlignment="Stretch" Margin="16,0,0,0" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="3*,2*" ColumnSpacing="12">
            <Border Grid.Column="0" Classes="panel" Padding="14">
                <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="10">
                    <TextBlock Classes="title" Text="Mining Desk" />
                    <Border Grid.Row="1" Classes="panel-soft" Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Name="ChallengePromptText" Classes="mono" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Name="ChallengeDifficultyText" HorizontalAlignment="Center" Opacity="0.85" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2" ColumnDefinitions="3*,Auto" ColumnSpacing="8">
                        <TextBox Name="MonitorAnswerBox" PlaceholderText="Type answer - Enter to submit" FontSize="18" Classes="mono" />
                        <Button Name="SmartphoneButton" Grid.Column="1" Width="120" Classes="shop" Content="Phone: Exchange" />
                    </Grid>

                    <Border Grid.Row="3" Classes="panel-soft" Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Name="FeedbackText" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Name="RewardMessageText" HorizontalAlignment="Center" TextWrapping="Wrap" />
                            <TextBlock Name="AlertText" FontSize="13" Foreground="#EAA43C" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Name="MonitorSubmitButton" Width="120" Classes="shop" Content="Submit" />
                        <Button Name="SaveButton" Width="96" Classes="shop" Content="Save" />
                        <Button Name="LoadButton" Width="96" Classes="shop" Content="Load" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Classes="panel" Padding="14">
                <Grid RowDefinitions="Auto,*,*,Auto" RowSpacing="10">
                    <TextBlock Classes="title" Text="Economy and Upgrades" />

                    <Border Grid.Row="1" Classes="panel-soft" Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="Auto-Miners" />
                            <Button Name="MonkeyButton" Classes="shop" />
                            <Button Name="YouthButton" Classes="shop" />
                            <Button Name="GpuButton" Classes="shop" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Classes="panel-soft" Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="Upgrades" />
                            <Button Name="ManualUpgradeButton" Classes="shop" />
                            <Button Name="EfficiencyUpgradeButton" Classes="shop" />
                            <Button Name="MarketUpgradeButton" Classes="shop" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="3" Classes="panel-soft" Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="Final Goal" />
                            <Button Name="SpaceshipButton" Classes="shop" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Name="ExchangeOverlay"
                Grid.RowSpan="2"
                IsVisible="False"
                Background="#99060A0D">
            <Border Width="640" Height="420" HorizontalAlignment="Center" VerticalAlignment="Center" Classes="panel" Padding="14">
                <Grid RowDefinitions="Auto,170,Auto,Auto" RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock FontSize="22" FontWeight="Bold" Text="KaiCoin Exchange" />
                        <Button Name="CloseExchangeButton" Grid.Column="1" Width="88" Classes="shop" Content="Close" />
                    </Grid>

                    <Border Grid.Row="1" Classes="panel-soft" Padding="10">
                        <Grid>
                            <Grid RowDefinitions="Auto,*,Auto" Margin="6,4,6,4">
                                <TextBlock Name="ExchangeMaxPriceText" Grid.Row="0" HorizontalAlignment="Right" FontSize="12" Opacity="0.78" />

                                <Grid Grid.Row="1">
                                    <Border Name="ExchangeGuideTop"
                                            Height="1"
                                            Background="#3AF5EEE4"
                                            VerticalAlignment="Top"
                                            IsVisible="False" />
                                    <Border Name="ExchangeGuideMid"
                                            Height="1"
                                            Background="#2AF5EEE4"
                                            VerticalAlignment="Center"
                                            IsVisible="False" />
                                    <Border Name="ExchangeGuideBottom"
                                            Height="1"
                                            Background="#3AF5EEE4"
                                            VerticalAlignment="Bottom"
                                            IsVisible="False" />
                                </Grid>

                                <TextBlock Name="ExchangeMinPriceText" Grid.Row="2" HorizontalAlignment="Right" FontSize="12" Opacity="0.78" />
                            </Grid>

                            <Polyline Name="ExchangePricePolyline"
                                      Stroke="#4FD0C9"
                                      StrokeThickness="2"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch" />

                            <TextBlock Name="ExchangeChartPlaceholder"
                                       Text="Collect at least 2 price points to render the chart"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Opacity="0.78"
                                       IsVisible="True" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" ColumnDefinitions="2*,Auto,Auto" ColumnSpacing="8">
                        <TextBox Name="SellQuantityBox" Classes="mono" FontSize="18" PlaceholderText="Sell quantity" />
                        <Button Name="SellButton" Grid.Column="1" Width="110" Classes="shop" Content="Sell" />
                        <TextBlock Name="ExchangeHintText" Grid.Column="2" VerticalAlignment="Center" Foreground="#EAA43C" />
                    </Grid>

                    <TextBlock Grid.Row="3" Text="Numeric keys route here while this modal is open. Enter sells." Opacity="0.8" />
                </Grid>
            </Border>
        </Border>

        <Border Name="LaunchOverlay"
                Grid.RowSpan="2"
                IsVisible="False"
                Background="#AA020304">
            <Grid>
                <TextBlock Name="LaunchMessageText" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,120" />
                <Border Name="RocketVisual"
                        Width="70"
                        Height="130"
                        CornerRadius="20"
                        Background="#EBE9D7"
                        BorderBrush="#364655"
                        BorderThickness="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,20" />
            </Grid>
        </Border>
    </Grid>
</Window>
