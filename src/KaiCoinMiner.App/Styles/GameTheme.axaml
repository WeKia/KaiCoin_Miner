<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <Color x:Key="PanelColor">#14232F</Color>
    <Color x:Key="PanelSoftColor">#1A2F3B</Color>
    <Color x:Key="AccentColor">#25C47A</Color>
    <Color x:Key="WarnColor">#D04C4C</Color>
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" />
    <SolidColorBrush x:Key="PanelSoftBrush" Color="{StaticResource PanelSoftColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="WarnBrush" Color="{StaticResource WarnColor}" />
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="Background" Value="#0C1820" />
    <Setter Property="Foreground" Value="#E8F2F6" />
  </Style>

  <Style Selector="Border.panel">
    <Setter Property="Background" Value="{StaticResource PanelBrush}" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="#2D4C5D" />
  </Style>

  <Style Selector="Border.panel-soft">
    <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BorderBrush" Value="#31586B" />
  </Style>

  <Style Selector="TextBlock.title">
    <Setter Property="FontSize" Value="20" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <Style Selector="TextBlock.mono">
    <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Courier New" />
  </Style>

  <Style Selector="Button.shop">
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
  </Style>
</Styles>
