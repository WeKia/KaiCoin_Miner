<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="KaiCoinMiner.App.Views.ShopView">
    <Border Background="#191a2b">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Margin="40,30,40,30">
                <TextBlock Grid.Row="0" Text="MINER SHOP" FontSize="32" FontWeight="Bold" Foreground="#E8F2F6" HorizontalAlignment="Center" Margin="0,0,0,20" />
                <StackPanel Grid.Row="1" Name="UpgradesPanel" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16" />
                <Border Grid.Row="2" Height="2" Background="#2D4C5D" Margin="0,0,0,16" />
                <StackPanel Grid.Row="3" Name="AutoMinersPanel" Spacing="12" Margin="0,0,0,16" MinHeight="420" />
                <StackPanel Grid.Row="4" Name="FinalItemsPanel" HorizontalAlignment="Center" />
            </Grid>
        </ScrollViewer>
    </Border>
</UserControl>
